{
  "manifest_version": 3,
  "name": "InclusiWeb",
  "version": "2.0",
  "description": "Leitor acessível com modo leitura",

  "permissions": ["activeTab", "storage"],

  "icons": {
    "16": "reader/icons/icon16.png",
    "32": "reader/icons/icon32.png",
    "48": "reader/icons/icon48.png",
    "128": "reader/icons/icon128.png"
  },

  "action": {
    "default_popup": "popup/popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"]
    }
  ],

  "commands": {
    "open-reader-mode": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Open InclusiWeb Reader Mode"
    }
  }
}