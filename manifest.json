{
  "manifest_version": 3,
  "name": "InclusiWeb",
  "version": "2.0",
  "description": "Leitor acessível com modo leitura",

  "permissions": ["activeTab", "storage"],

  "action": {
    "default_popup": "popup/popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"]
    }
  ]
}