{
  "manifest_version": 3,
  "name": "Minha Primeira Extensão",
  "version": "1.0",

  "permissions": ["activeTab", "storage"],

  "description": "Uma extensão simples de exemplo.",
  "action": {
    "default_popup": "popup/popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"]
    }
  ]
}
